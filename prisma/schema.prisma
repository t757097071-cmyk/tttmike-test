generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  phoneHash      String   @unique @map("phone_hash")
  phoneEncrypted String   @map("phone_encrypted")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  lastLoginAt    DateTime @map("last_login_at")

  wallet              UserWallet?
  ledger              WalletLedger[]
  rechargeOrders      RechargeOrder[]
  wishRecords         WishRecord[]
  lampRecords         LampRecord[]
  drawRecords         DrawRecord[]
  featureConsumptions FeatureConsumption[]

  @@map("users")
}

model UserWallet {
  userId           String   @id @map("user_id")
  wishPowerBalance Int      @default(0) @map("wish_power_balance")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_wallets")
}

model WalletLedger {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  type         String
  amount       Int
  balanceAfter Int      @map("balance_after")
  sourceType   String   @map("source_type")
  sourceId     String   @map("source_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("wallet_ledger")
}

model RechargePackage {
  id          String @id
  name        String
  priceCents  Int    @map("price_cents")
  wishPower   Int    @map("wish_power")
  status      String @default("active")
  sortOrder   Int    @default(0) @map("sort_order")

  orders RechargeOrder[]

  @@map("recharge_packages")
}

model RechargeOrder {
  id             String    @id @default(cuid())
  orderNo        String    @unique @map("order_no")
  userId         String    @map("user_id")
  packageId      String    @map("package_id")
  priceCents     Int       @map("price_cents")
  wishPower      Int       @map("wish_power")
  paymentChannel String    @map("payment_channel")
  status         String    @default("pending")
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user         User                 @relation(fields: [userId], references: [id])
  package      RechargePackage      @relation(fields: [packageId], references: [id])
  transactions PaymentTransaction[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("recharge_orders")
}

model PaymentTransaction {
  id              String   @id @default(cuid())
  orderId         String   @map("order_id")
  providerTradeNo String   @map("provider_trade_no")
  rawNotify       Json     @map("raw_notify")
  verifiedAt      DateTime @default(now()) @map("verified_at")

  order RechargeOrder @relation(fields: [orderId], references: [id])

  @@unique([orderId, providerTradeNo])
  @@map("payment_transactions")
}

model WishRecord {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  type          String
  content       String
  nickname      String?
  meritSnapshot Int      @map("merit_snapshot")
  cost          Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("wish_records")
}

model LampRecord {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  lampName    String   @map("lamp_name")
  wishType    String   @map("wish_type")
  cost        Int
  nickname    String?
  wishContent String   @map("wish_content")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("lamp_records")
}

model DrawRecord {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  cost      Int
  result    Json
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("draw_records")
}

model FeatureConsumption {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  feature     String
  amount      Int
  businessId  String   @map("business_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([feature, businessId])
  @@index([userId, createdAt])
  @@map("feature_consumptions")
}
